# Игнорировать все CSV файлы в проекте
*.csv

# Но не игнорировать конкретно data.json (он нам нужен)
!data.json

# Игнорировать папку с исходными CSV
/data/
!/data/README.md

# Игнорировать Python кэш
__pycache__/
*.pyc

# Игнорировать временные файлы
.DS_Store
*.log
*.tmp

# Игнорировать виртуальное окружение Python (если используете)
venv/
env/
.env